# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
# .vscode/settings.json ships in the template (carries shipped Claude Code permission-mode
# recommendations — see TROUBLESHOOTING.md "Permissions / bypass / statusline" for the typo
# fix forkers need). Other .vscode/ content is developer-machine-specific.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
.quarto/

# quality_reports/ — per-project session logs, plans, specs, merges.
# The directory structure ships in the template (via .gitkeep), but the
# content is PROJECT-INTERNAL and shouldn't be inherited by forks.
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/preregistrations/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep

# R analysis outputs (generated artifacts; keep scripts, ignore outputs)
scripts/R/_outputs/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds

# ==============================================================================
# Raw research data + STATA analysis (PIDPS dissertation, 2026-05-04)
# ==============================================================================
# Raw microdata (FHES, APCS, etc.) — privacy + size protection.
# Directory structure ships via .gitkeep; contents stay local.
master_supporting_docs/own_drafts/rawdata/*
!master_supporting_docs/own_drafts/rawdata/.gitkeep

# STATA do-files + logs from term-paper analysis.
# Directory structure ships via .gitkeep; .do/.log decision pending Dohyeon review.
# (Note: *.log is already ignored at line 11 as a LaTeX/STATA build artifact —
#  remove that pattern or whitelist if you decide to commit STATA logs.)
master_supporting_docs/own_drafts/stata_analysis/*
!master_supporting_docs/own_drafts/stata_analysis/.gitkeep

# Supporting papers (출판사 저작권 PDFs — replication package에 미포함)
master_supporting_docs/supporting_papers/*.pdf
!master_supporting_docs/supporting_papers/.gitkeep
