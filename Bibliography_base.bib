% ==============================================================================
% Bibliography for PIDPS Research (paper/ko + paper/en + slides)
% ==============================================================================
%
% Naming convention: AuthorYear_keyword
% Example: ChoiJodlowski2025_landreg, CaballeroEngel1999_ssmodel
%
% ------------------------------------------------------------------------------
% BILINGUAL DUAL-FIELD CONVENTION (per .claude/rules/quality-gates.md §8)
% ------------------------------------------------------------------------------
% Korean-authored entries MUST carry BOTH forms:
%   - `author`     = Korean form (김태화 and 양승룡)         → used by paper/ko
%   - `author_en`  = English form (Kim, Tae-hwa and Yang, ...) → used by paper/en
%   - `title`      = Korean title                              → used by paper/ko
%   - `title_en`   = English title                             → used by paper/en
%
% Example pattern (delete after replacing with real entries):
%
%   @article{KimYang2021_pidps,
%     author    = {김태화 and 양승룡},
%     author_en = {Kim, Tae-hwa and Yang, Seung-ryong},
%     title     = {공익직불제 정책 분석},
%     title_en  = {Policy Analysis of the Public-Interest Direct Payment Scheme},
%     journal   = {농업경영·정책연구},
%     year      = {2021}
%   }
%
% English-only entries (Choi-Jodlowski 2025, Caballero-Engel 1999, etc.) need
% only `author` and `title` in English — no dual fields required.
%
% Citation format enforcement is directory-scoped:
%   paper/ko/**/*.tex  → Korean form (김태화·양승룡(2021))
%   paper/en/**/*.tex  → Author-year English (Kim and Yang, 2021)
% `/validate-bib` (extended in Step 4) detects format mismatch by file path;
% until then, manual + CoVe (`/verify-claims`) enforcement.
% ==============================================================================

% ------------------------------------------------------------------------------
% EXAMPLE ENTRIES — delete these and add your own
% ------------------------------------------------------------------------------

@book{Example2024_book,
  author    = {Lastname, Firstname},
  title     = {An Example Book Title},
  publisher = {Example University Press},
  year      = {2024},
  address   = {City, State}
}

@article{Example2025_article,
  author  = {Lastname, Firstname and Coauthor, Name},
  title   = {An Example Journal Article Title},
  journal = {Journal of Example Studies},
  volume  = {10},
  number  = {2},
  pages   = {100--125},
  year    = {2025}
}
